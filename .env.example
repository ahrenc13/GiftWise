# GiftWise Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it's in .gitignore)

# ============================================================================
# REQUIRED - App will not function without these
# ============================================================================

# Claude API (for profile analysis and gift curation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================================
# AFFILIATE NETWORKS
# ============================================================================

# Amazon Associates
RAPIDAPI_KEY=your_rapidapi_key_here
AMAZON_AFFILIATE_TAG=your_amazon_tag_here

# eBay Partner Network
EBAY_CLIENT_ID=your_ebay_client_id_here
EBAY_CLIENT_SECRET=your_ebay_client_secret_here

# Awin (formerly ShareASale)
AWIN_DATA_FEED_API_KEY=your_awin_api_key_here

# CJ Affiliate (11M+ products via GraphQL API)
CJ_API_KEY=your_cj_personal_access_token_here
CJ_COMPANY_ID=your_cj_publisher_company_id_here
CJ_PUBLISHER_ID=your_cj_publisher_website_id_here

# Skimlinks (pending approval)
SKIMLINKS_PUBLISHER_ID=your_skimlinks_publisher_id_here
SKIMLINKS_CLIENT_ID=your_skimlinks_client_id_here
SKIMLINKS_CLIENT_SECRET=your_skimlinks_client_secret_here

# FlexOffers (if approved)
FLEXOFFERS_API_KEY=your_flexoffers_api_key_here

# Etsy (awaiting developer credentials)
ETSY_API_KEY=your_etsy_api_key_here

# ============================================================================
# OPTIONAL - Feature toggles and configuration
# ============================================================================

# Claude Model Selection (for A/B testing)
CLAUDE_PROFILE_MODEL=claude-sonnet-4-20250514
CLAUDE_CURATOR_MODEL=claude-sonnet-4-20250514

# Admin Dashboard
ADMIN_DASHBOARD_KEY=your_secret_dashboard_key_here

# Flask Configuration
FLASK_SECRET_KEY=your_flask_secret_key_here
FLASK_ENV=production

# Session Configuration
SESSION_TYPE=filesystem

# ============================================================================
# REDDIT SCOUT (scripts/reddit_scout.py)
# Register at reddit.com/prefs/apps — type: script
# ============================================================================
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=GiftWise Scout/1.0 by u/your_reddit_username
